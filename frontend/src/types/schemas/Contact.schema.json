{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Contact",
  "definitions": {
    "Contact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "org_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "$ref": "#/definitions/UserRole"
        },
        "contact_preference": {
          "type": "string",
          "enum": [
            "SMS",
            "Email",
            "Both"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "trades": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "license_number": {
          "type": "string"
        },
        "address_city": {
          "type": "string"
        },
        "address_state": {
          "type": "string"
        },
        "address_zip": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "portal_enabled": {
          "type": "boolean"
        },
        "source": {
          "type": "string"
        },
        "last_contacted_at": {
          "type": "string"
        },
        "avg_response_time_hours": {
          "type": "number"
        },
        "on_time_rate": {
          "type": "number"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "org_id",
        "name",
        "role",
        "contact_preference",
        "created_at",
        "portal_enabled",
        "source"
      ],
      "additionalProperties": false,
      "description": "Contact represents a shared contact model. See API_AND_TYPES_SPEC.md Section 4.1"
    },
    "UserRole": {
      "type": "string",
      "enum": [
        "Admin",
        "Builder",
        "PM",
        "Viewer",
        "Client",
        "Subcontractor"
      ],
      "description": "UserRole defines the permissions and identity of a PortalUser or User. See API_AND_TYPES_SPEC.md Section 1.2"
    }
  }
}