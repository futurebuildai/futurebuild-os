{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/InvoiceExtraction",
  "definitions": {
    "InvoiceExtraction": {
      "type": "object",
      "properties": {
        "vendor": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "invoice_number": {
          "type": "string"
        },
        "total_amount_cents": {
          "type": "string"
        },
        "line_items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/InvoiceExtractionItem"
          }
        },
        "suggested_wbs_code": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      },
      "required": [
        "vendor",
        "date",
        "invoice_number",
        "total_amount_cents",
        "line_items",
        "suggested_wbs_code",
        "confidence"
      ],
      "additionalProperties": false,
      "description": "InvoiceExtraction represents the output of document analysis. See API_AND_TYPES_SPEC.md Section 3.1"
    },
    "InvoiceExtractionItem": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unit_price_cents": {
          "type": "string"
        },
        "total_cents": {
          "type": "string"
        }
      },
      "required": [
        "description",
        "quantity",
        "unit_price_cents",
        "total_cents"
      ],
      "additionalProperties": false,
      "description": "InvoiceExtractionItem represents a single line item in an invoice."
    }
  }
}