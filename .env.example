# FutureBuild Environment Variables Template
# Copy this file to .env and fill in real values.
# DO NOT COMMIT .env files to version control!

# ----------------------
# DATABASE
# ----------------------
DATABASE_URL=postgres://user:password@localhost:5432/futurebuild?sslmode=disable

# ----------------------
# REDIS (Asynq Task Queue)
# ----------------------
REDIS_URL=redis://localhost:6379

# ----------------------
# AUTHENTICATION
# ----------------------
JWT_SECRET=your-super-secret-jwt-signing-key-min-32-chars

# ----------------------
# AI / VERTEX AI
# ----------------------
GEMINI_API_KEY=your-google-ai-api-key

# ----------------------
# OBJECT STORAGE (DO Spaces / S3-Compatible)
# ----------------------
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_ENDPOINT=sgp1.digitaloceanspaces.com
SPACES_BUCKET=futurebuild-staging

# ----------------------
# STRIPE (SaaS Billing)
# ----------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ----------------------
# APPLICATION
# ----------------------
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
