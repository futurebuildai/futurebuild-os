# FutureBuild Environment Variables Template
# Copy this file to .env and fill in real values.
# DO NOT COMMIT .env files to version control!
#
# See LAUNCH_PLAN.md and deployment/production/app.yaml for production config.

# ==============================================================================
# CORE APPLICATION
# ==============================================================================
APP_ENV=development                    # development | staging | production
APP_PORT=8080
BASE_URL=http://localhost:8080         # Public URL for magic links

# Trusted proxies for rate limiting (comma-separated CIDRs)
TRUSTED_PROXIES=127.0.0.1

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/futurebuild?sslmode=disable

# ==============================================================================
# REDIS (Asynq Task Queue & Session Store)
# ==============================================================================
REDIS_URL=redis://localhost:6379

# ==============================================================================
# AUTHENTICATION
# ==============================================================================
# JWT secret must be at least 32 characters for HS256
JWT_SECRET=your-super-secret-jwt-signing-key-min-32-chars
JWT_EXPIRY=24h

# ==============================================================================
# EMAIL (SendGrid)
# ==============================================================================
# Required for magic link authentication and notifications
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM_ADDRESS=noreply@futurebuild.ai
EMAIL_FROM_NAME=FutureBuild

# ==============================================================================
# SMS (Twilio)
# ==============================================================================
# Required for portal one-time links and subcontractor notifications
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ==============================================================================
# WEBHOOK SECURITY
# ==============================================================================
# Secret for verifying inbound webhook signatures (SMS, email)
WEBHOOK_SECRET=your-webhook-signing-secret

# ==============================================================================
# AI / VERTEX AI (Google Cloud)
# ==============================================================================
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL_FLASH_ID=gemini-2.5-flash
VERTEX_MODEL_PRO_ID=gemini-1.5-pro
VERTEX_MODEL_EMBEDDING_ID=text-embedding-004

# Path to Google Cloud service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ==============================================================================
# FUTURESHADE (Intelligence Layer)
# ==============================================================================
FUTURESHADE_ENABLED=false
FUTURESHADE_API_KEY=
FUTURESHADE_MODEL_ID=gemini-2.5-flash

# ==============================================================================
# OBJECT STORAGE (DO Spaces / S3-Compatible)
# ==============================================================================
S3_ENDPOINT=sgp1.digitaloceanspaces.com
S3_BUCKET=futurebuild-dev
S3_ACCESS_KEY=your-spaces-access-key
S3_SECRET_KEY=your-spaces-secret-key

# ==============================================================================
# AUDIT & OBSERVABILITY
# ==============================================================================
# Path for local audit WAL (fallback when DB unavailable)
AUDIT_WAL_PATH=/var/log/futurebuild/audit.wal

# Project root for shadow docs service
PROJECT_ROOT=.

# ==============================================================================
# WORKER CONFIGURATION
# ==============================================================================
WORKER_QUEUE_CRITICAL=6
WORKER_QUEUE_DEFAULT=3
WORKER_QUEUE_LOW=1

# ==============================================================================
# BILLING (Stripe) - Future
# ==============================================================================
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ==============================================================================
# INVOICE PROCESSING
# ==============================================================================
# Minimum AI confidence to auto-approve invoices (0.0 - 1.0)
INVOICE_CONFIDENCE_THRESHOLD=0.85
