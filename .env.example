# Database
DATABASE_URL=postgres://brain:brain@localhost:5434/futurebuild_brain?sslmode=disable
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_TIMEOUT=5s

# Server
PORT=8081
ISSUER_URL=http://localhost:8081

# OIDC
OIDC_CRYPTO_KEY=  # 32-byte hex string for token encryption (leave empty for dev)
DEV_MODE=true     # Allow http:// redirect URIs

# Redis (future)
REDIS_URL=redis://localhost:6379
